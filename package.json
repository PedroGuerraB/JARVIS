{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently -n orchestrator,dashboard -c magenta,cyan \"pnpm --filter @jarvis/orchestrator dev\" \"pnpm --filter @jarvis/dashboard dev\"",
    "dev:orchestrator": "pnpm --filter @jarvis/orchestrator dev",
    "dev:dashboard": "pnpm --filter @jarvis/dashboard dev",
    "build": "pnpm -r --if-present run build",
    "type-check": "pnpm -r --if-present run type-check",
    "build:packages": "pnpm --filter @jarvis/shared build && pnpm --filter @jarvis/db build && pnpm --filter @jarvis/memory build && pnpm --filter @jarvis/tools build && pnpm --filter @jarvis/agents build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3"
  }
}
